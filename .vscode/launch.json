{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome",
      "type": "chrome",
      "request": "launch",
      "runtimeArgs": [
        "--disable-features=Translate",
        "--incognito"
      ],
      "preLaunchTask": "Start and watch for changes",
      "url": "http://localhost:8000/",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "*": "${workspaceFolder}/*"
      },
      "smartStep": true
    },
    {
      "name": "ProperDocs",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "Start and watch for changes",
      "program": "/Library/Frameworks/Python.framework/Versions/3.13/bin/properdocs",
      "args": ["build"],
      "env": {
        "PYTHONPATH": "."
      }
    },
    {
        "name": "Debug ProperDocs Plugin",
        "type": "debugpy",
        "request": "launch",
        "module": "properdocs",
        "args": [
            "build",
            "--clean",
            "-v"
        ],
        "cwd": "/Users/aaron/jaywhj.github.io",
        "console": "integratedTerminal",
        "justMyCode": true
    },
    {
      "name": "ProperDocs server",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "Start and watch for changes",
      "program": "/Library/Frameworks/Python.framework/Versions/3.13/bin/properdocs",
      "args": ["serve", "--watch-theme"],
      "env": {
        "PYTHONPATH": "."
      }
    },
    {
      "name": "ProperDocs server (dirty)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "Start and watch for changes",
      "program": "/Library/Frameworks/Python.framework/Versions/3.13/bin/properdocs",
      "args": ["serve", "--watch-theme", "--dirtyreload"],
      "env": {
        "PYTHONPATH": "."
      }
    }
  ],
  "compounds": [
    {
      "name": "Chrome + ProperDocs server",
      "configurations": ["Chrome", "ProperDocs server"]
    },
    {
      "name": "Chrome + ProperDocs server (dirty)",
      "configurations": ["Chrome", "ProperDocs server (dirty)"]
    }
  ]
}
